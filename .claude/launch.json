{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "verse-web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "--prefix", "verse-web", "dev"],
      "port": 5173,
      "autoPort": false
    },
    {
      "name": "verse-web-next",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "--prefix", "verse-web-next", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "verse-backend",
      "runtimeExecutable": "env",
      "runtimeArgs": [
        "ADDR=:8080",
        "HTTP_PORT=8080",
        "DATABASE_URL=postgres://pixelkjv:pixelkjv_dev_pw@localhost:5432/pixelkjv?sslmode=disable",
        "JWT_SECRET=change-me-in-production",
        "JWT_ACCESS_TTL=15",
        "KJV_DATA_DIR=../files/data/kjv",
        "go", "run", "./cmd/api"
      ],
      "cwd": "verse-backend",
      "port": 8080,
      "autoPort": false
    }
  ]
}

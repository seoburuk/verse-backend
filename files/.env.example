# .env.example
# 이 파일을 복사해 .env 로 만들어 사용:  cp .env.example .env
# .env 는 절대 커밋하지 않는다 (.gitignore 에 포함됨).

DB_USER=pixelkjv
DB_PASSWORD=pixelkjv_dev_pw
DB_NAME=pixelkjv
DB_PORT=5432
DB_HOST=localhost

# golang-migrate / 적재 스크립트가 쓰는 단일 접속 문자열.
# sslmode=disable 는 로컬 개발 전용. 운영에서는 절대 disable 금지.
DATABASE_URL=postgres://pixelkjv:pixelkjv_dev_pw@localhost:5432/pixelkjv?sslmode=disable

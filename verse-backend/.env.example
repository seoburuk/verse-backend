ADDR=:8080
DATABASE_URL=postgres://pixelkjv:pixelkjv_dev_pw@localhost:5432/pixelkjv?sslmode=disable
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=15
KJV_DATA_DIR=../files/data/kjv
CORS_ORIGIN=http://localhost:3000
GOOGLE_CLIENT_ID=
# Sign in with Apple. id_token audience 검증에 사용.
# APPLE_BUNDLE_ID: iOS 네이티브 앱 로그인용(앱 번들 ID).
# APPLE_SERVICE_ID: 웹 로그인용(Apple 개발자 포털 Services ID, NEXT_PUBLIC_APPLE_SERVICE_ID와 동일).
# 둘 다 미설정 시 애플 로그인은 "not configured"로 거부됨.
APPLE_BUNDLE_ID=com.pixbible.verseFlutter
APPLE_SERVICE_ID=com.pixbible.auth
